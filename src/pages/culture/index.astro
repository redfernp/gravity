---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = await getCollection('culture');
const sorted = articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Culture | Gravity Snowsports"
  description="Film, photography, interviews, and the stories behind extreme snow sports. The people, the art, the obsession."
>
  <section class="relative bg-gravity-bg py-24 px-4 noise-overlay">
    <div class="absolute inset-0 bg-gradient-to-b from-[#1a0d10] to-gravity-bg"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <span class="section-label block mb-4">Film, Photography, Stories</span>
      <h1 class="font-display font-black text-7xl md:text-9xl text-white uppercase leading-tight">
        CULTURE<span class="text-gravity">.</span>
      </h1>
      <p class="text-zinc-400 mt-4 text-lg max-w-2xl">
        Long-form interviews. Film features. The photographers behind the best edits. The stories that define what this sport actually is.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {sorted.map((article, i) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.slug}
            collection="culture"
            pubDate={article.data.pubDate}
            category={article.data.category}
            image={article.data.image}
            author={article.data.author}
            featured={i === 0}
          />
        ))}
      </div>
    ) : (
      <p class="text-zinc-500">Culture content coming soon.</p>
    )}
  </div>
</BaseLayout>
