---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = await getCollection('shred');
const sorted = articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Shred | Gravity Snowsports"
  description="Freeriding, park and pipe, splitboarding, ski touring. Every discipline with the depth it deserves."
>
  <section class="relative bg-gravity-bg py-24 px-4 noise-overlay">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0d2010] to-gravity-bg"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <span class="section-label block mb-4">Disciplines</span>
      <h1 class="font-display font-black text-7xl md:text-9xl text-white uppercase leading-none">
        SHRED<span class="text-gravity">.</span>
      </h1>
      <p class="text-zinc-400 mt-4 text-lg max-w-2xl">
        Freeriding. Park and pipe. Splitboarding. Ski touring. Not instructional. Opinionated, experience-led, rider-voiced.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {sorted.map((article, i) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.slug}
            collection="shred"
            pubDate={article.data.pubDate}
            category={article.data.category}
            image={article.data.image}
            author={article.data.author}
            featured={i === 0}
          />
        ))}
      </div>
    ) : (
      <p class="text-zinc-500">Content coming soon.</p>
    )}
  </div>
</BaseLayout>
