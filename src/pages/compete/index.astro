---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const articles = await getCollection('compete');
const sorted = articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featured = sorted.find(a => a.data.featured) || sorted[0];
const rest = sorted.filter(a => a !== featured);
---

<BaseLayout
  title="Compete | Gravity Snowsports"
  description="X Games, Freeride World Tour, BUSC Varsity, and the UK underground scene. Competition coverage that takes the sport seriously."
>
  <!-- Section Hero -->
  <section class="relative bg-gravity-bg py-24 px-4 noise-overlay">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0d1828] to-gravity-bg"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <span class="section-label block mb-4">Competition Coverage</span>
      <h1 class="font-display font-black text-7xl md:text-9xl text-white uppercase leading-none">
        COMPETE<span class="text-gravity">.</span>
      </h1>
      <p class="text-zinc-400 mt-4 text-lg max-w-2xl">
        X Games. Freeride World Tour. BUSC. The dry slope underground. Every competition that matters, covered without compromise.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Featured -->
    {featured && (
      <div class="mb-12">
        <ArticleCard
          title={featured.data.title}
          description={featured.data.description}
          slug={featured.slug}
          collection="compete"
          pubDate={featured.data.pubDate}
          category={featured.data.category}
          image={featured.data.image}
          author={featured.data.author}
          featured={true}
          size="large"
        />
      </div>
    )}

    <!-- All Articles -->
    {rest.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {rest.map(article => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.slug}
            collection="compete"
            pubDate={article.data.pubDate}
            category={article.data.category}
            image={article.data.image}
            author={article.data.author}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
