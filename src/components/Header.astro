---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const navItems = [
  { label: 'Compete', href: '/compete' },
  { label: 'Shred', href: '/shred' },
  { label: 'Gear Lab', href: '/gear-lab' },
  { label: 'Destinations', href: '/destinations' },
  { label: 'Culture', href: '/culture' },
  { label: 'Brand Spotlights', href: '/brand-spotlights' },
];

const currentPath = Astro.url.pathname;

const headerClasses = transparent
  ? 'fixed top-0 left-0 right-0 z-50 transition-all duration-300'
  : 'fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-gravity-bg/80 backdrop-blur-md border-b border-zinc-800/40';
---

<header id="site-header" class={`${headerClasses} overflow-visible`} data-transparent={transparent ? 'true' : undefined}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 overflow-visible">

      <!-- Logo -->
      <a href="/" class="flex flex-col items-start group overflow-visible">
        <span class="font-display font-black text-2xl text-white tracking-tight group-hover:text-gravity transition-colors duration-200 pb-[3px]" style="line-height: 1.15;">
          GRAVITY<span class="text-gravity">.</span>
        </span>
        <span class="font-display font-bold text-[0.55rem] text-zinc-400 uppercase tracking-[0.35em] group-hover:text-zinc-300 transition-colors duration-200" style="line-height: 1; margin-top: -1px;">
          Snowsports
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-7">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`text-xs font-bold uppercase tracking-widest transition-colors duration-200 font-display ${
              currentPath.startsWith(item.href)
                ? 'text-gravity'
                : 'text-zinc-400 hover:text-white'
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden text-zinc-400 hover:text-white transition-colors p-2"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden lg:hidden bg-gravity-bg border-t border-zinc-800">
    <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`text-sm font-bold uppercase tracking-widest py-2 font-display transition-colors duration-200 ${
            currentPath.startsWith(item.href)
              ? 'text-gravity'
              : 'text-zinc-400 hover:text-white'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');

  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  const isTransparent = header?.hasAttribute('data-transparent');

  function updateHeader() {
    if (!header) return;
    if (window.scrollY > 60) {
      // Scrolled — always solid
      header.style.backgroundColor = 'rgba(8,12,20,0.97)';
      header.style.borderBottom = '1px solid rgba(39,39,42,0.8)';
      header.style.backdropFilter = 'blur(12px)';
      header.style.webkitBackdropFilter = 'blur(12px)';
    } else if (isTransparent) {
      // Top of homepage — fully transparent
      header.style.backgroundColor = 'transparent';
      header.style.borderBottom = '1px solid transparent';
      header.style.backdropFilter = 'none';
      header.style.webkitBackdropFilter = 'none';
    } else {
      // Top of other pages — semi-transparent
      header.style.backgroundColor = '';
      header.style.borderBottom = '';
      header.style.backdropFilter = '';
      header.style.webkitBackdropFilter = '';
    }
  }

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>
