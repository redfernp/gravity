---
interface Props {
  title: string;
  description: string;
  slug: string;
  collection: string;
  pubDate: Date;
  category?: string;
  image?: string;
  author?: string;
  featured?: boolean;
  size?: 'default' | 'large' | 'small';
  revealDelay?: number;
}

const {
  title,
  description,
  slug,
  collection,
  pubDate,
  category,
  image,
  author = 'Gravity Team',
  featured = false,
  size = 'default',
  revealDelay = 0,
} = Astro.props;

const url = `/${collection}/${slug}/`;
const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const delayClass = revealDelay > 0 ? `delay-${revealDelay}` : '';
---

<article class={`article-card group relative bg-gravity-card border border-zinc-800 overflow-hidden reveal-on-scroll ${delayClass} ${featured ? 'md:col-span-2 md:row-span-2' : ''}`}>

  <!-- Image / Gradient placeholder -->
  <a href={url} class={`block overflow-hidden relative ${size === 'large' || featured ? 'aspect-[16/9]' : size === 'small' ? 'aspect-[3/2]' : 'aspect-[16/9]'}`}>
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full relative overflow-hidden" style="background: linear-gradient(135deg, #141a22 0%, #080c14 100%);">
        <!-- Decorative diagonal lines -->
        <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, #c8ff00 0px, #c8ff00 1px, transparent 1px, transparent 40px);"></div>
        <!-- Corner accent -->
        <div class="absolute top-3 right-3 w-6 h-6 border-t-2 border-r-2 border-gravity opacity-40"></div>
        <div class="absolute bottom-3 left-3 w-6 h-6 border-b-2 border-l-2 border-gravity opacity-20"></div>
      </div>
    )}
    <!-- Hover overlay -->
    <div class="absolute inset-0 bg-gravity opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>
  </a>

  <!-- Content -->
  <div class={`p-5 ${featured ? 'md:p-8' : ''}`}>
    {category && (
      <span class="gravity-badge mb-3 block w-fit">{category}</span>
    )}

    <h3 class={`article-title mb-2 group-hover:text-gravity transition-colors duration-200 ${
      featured ? 'text-3xl md:text-4xl' : size === 'large' ? 'text-2xl md:text-3xl' : size === 'small' ? 'text-lg' : 'text-xl md:text-2xl'
    } font-display uppercase`}>
      <a href={url}>{title}</a>
    </h3>

    <p class={`text-zinc-500 leading-relaxed mb-4 line-clamp-2 pb-0.5 ${featured ? 'text-base' : 'text-sm'}`}>
      {description}
    </p>

    <div class="flex items-center justify-between text-xs">
      <span class="text-zinc-600 font-medium tracking-wide">{author}</span>
      <span class="text-zinc-700 tabular-nums">{formattedDate}</span>
    </div>
  </div>
</article>
